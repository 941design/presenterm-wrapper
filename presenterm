#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="${IMAGE_NAME:-presenterm-wrapper}"
TAG="${TAG:-latest}"
PRESENTERM_THEME="${PRESENTERM_THEME:-catppuccin-frappe}"
PRESENTERM_DETACH="${PRESENTERM_DETACH:-1}"

CWD_DIR="$(pwd)"
CONTAINER_WORKDIR="/data"
INPUT_ARG=""
INPUT_REL_PATH=""
HAS_THEME_FLAG=0
INIT_FILE=""

# Kitty launch font size: computed dynamically from config
KITTY_FONT_SIZE=9  # default, will be computed below

compute_kitty_font_size() {
  local input_file="$1"
  local config_file="$2"

  # Call Python to compute the optimal base font size
  python3 - "$input_file" "$config_file" <<'PYEOF'
import sys
import yaml
import os

def compute_font_sizes(target_pt, heading_ratio):
    """Compute optimal (base, body_mult, heading_mult)"""
    best_error = float('inf')
    best = (9, 3, 2)

    for body_mult in range(1, 8):
        base = round(target_pt / body_mult)
        heading_mult = max(1, min(7, round(body_mult * heading_ratio)))

        body_error = abs(body_mult * base - target_pt)
        ratio_error = abs(heading_mult / body_mult - heading_ratio) * target_pt
        total_error = body_error + ratio_error

        if total_error < best_error:
            best_error = total_error
            best = (base, body_mult, heading_mult)

    return best

# Built-in defaults (must match DEFAULTS in auto_presenterm_slides.py)
font_size = 28
heading_ratio = 1.4

# Optionally load from config file if provided
if len(sys.argv) > 2 and sys.argv[2]:
    config_path = sys.argv[2]
    if os.path.exists(config_path):
        try:
            with open(config_path, 'r') as f:
                config = yaml.safe_load(f) or {}
            wrapper = config.get('wrapper', {})
            font_size = wrapper.get('font_size', font_size)
            heading_ratio = wrapper.get('heading_ratio', heading_ratio)
        except Exception:
            pass

# Check frontmatter for overrides
if len(sys.argv) > 1:
    input_file = sys.argv[1]
    if os.path.exists(input_file):
        try:
            with open(input_file, 'r') as f:
                lines = f.readlines()
            if lines and lines[0].strip() == '---':
                for i in range(1, len(lines)):
                    if lines[i].strip() == '---':
                        break
                    if ':' in lines[i]:
                        key, val = lines[i].split(':', 1)
                        key = key.strip().lower()
                        val = val.split('#')[0].strip().strip('"').strip("'")
                        if key == 'font_size':
                            try:
                                font_size = int(val)
                            except ValueError:
                                pass
                        elif key == 'heading_ratio':
                            try:
                                heading_ratio = float(val)
                            except ValueError:
                                pass
        except Exception:
            pass

base, body_mult, heading_mult = compute_font_sizes(font_size, heading_ratio)
print(base)
PYEOF
}

extract_title() {
  local file="$1"
  local title=""

  # Prefer YAML frontmatter "title:" when frontmatter is present.
  if [[ "$(head -n 1 "$file")" == "---" ]]; then
    title="$(awk '
      NR==1 { in_fm=1; next }
      in_fm && /^---[[:space:]]*$/ { exit }
      in_fm && /^[[:space:]]*title[[:space:]]*:/ {
        sub(/^[[:space:]]*title[[:space:]]*:[[:space:]]*/, "", $0)
        print
        exit
      }
    ' "$file")"
  fi

  # Fallback to first H1.
  if [[ -z "$title" ]]; then
    title="$(awk '
      /^---[[:space:]]*$/ { in_fm = !in_fm; next }
      in_fm { next }
      /^[[:space:]]*#[[:space:]]+/ {
        sub(/^[[:space:]]*#[[:space:]]+/, "", $0)
        print
        exit
      }
    ' "$file")"
  fi

  # Trim surrounding quotes from frontmatter value.
  title="${title#\"}"
  title="${title%\"}"
  title="${title#\'}"
  title="${title%\'}"

  if [[ -z "$title" ]]; then
    title="$REL_INPUT_PATH"
  fi
  printf '%s\n' "$title"
}

REL_ARGS=()
expecting_init_file=0
for arg in "$@"; do
  if [[ "$expecting_init_file" -eq 1 ]]; then
    INIT_FILE="$arg"
    expecting_init_file=0
    continue
  fi

  if [[ "$arg" == "--init" ]]; then
    expecting_init_file=1
    continue
  fi
  if [[ "$arg" == --init=* ]]; then
    INIT_FILE="${arg#--init=}"
    continue
  fi

  conv="$arg"
  if [[ "$arg" == "--theme" || "$arg" == --theme=* ]]; then
    HAS_THEME_FLAG=1
  fi

  if [[ "$conv" == /* ]]; then
    case "$conv" in
      "${CWD_DIR}"/*) conv="${conv#${CWD_DIR}/}" ;;
    esac
  fi
  while [[ "$conv" == ./* ]]; do
    conv="${conv#./}"
  done

  if [[ -z "$INPUT_ARG" && "$conv" != -* && -f "${CWD_DIR}/${conv}" ]]; then
    INPUT_ARG="${arg}"
    INPUT_REL_PATH="${conv}"
    rel_dir="$(dirname -- "${INPUT_REL_PATH}")"
    if [[ "$rel_dir" != "." ]]; then
      CONTAINER_WORKDIR="/data/${rel_dir}"
    fi
  fi

  REL_ARGS+=("$conv")
done

if [[ "$expecting_init_file" -eq 1 ]]; then
  echo "Missing filename for --init" >&2
  exit 2
fi

if [[ -n "$INIT_FILE" ]]; then
  if [[ "$INIT_FILE" == */* || "$INIT_FILE" == .*/* ]]; then
    echo "--init expects a file name in the current working directory." >&2
    exit 2
  fi
  if [[ -z "$INIT_FILE" ]]; then
    echo "Missing filename for --init" >&2
    exit 2
  fi
  if [[ "$INIT_FILE" != *.md ]]; then
    echo "--init requires a markdown filename ending in .md" >&2
    exit 2
  fi
  if [[ -e "${CWD_DIR}/${INIT_FILE}" || -L "${CWD_DIR}/${INIT_FILE}" ]]; then
    echo "Refusing to overwrite existing file: ${INIT_FILE}" >&2
    exit 1
  fi

  tmp_init_file="$(mktemp "${CWD_DIR}/.presenterm-init.XXXXXX")"
  cat > "${tmp_init_file}" <<'EOF'
---
title: My Presentation
author: Your Name
date: 2026-02-17
theme:
  override:
    footer:
      style: template
      left:
        image: mustwork-logo.png
---

# My Presentation

Short subtitle or context for this deck.

## Agenda

- Intro
- Main topic
- Demo
- Q&A

## Key Point

Use simple top-level headings for slide boundaries.

### Detail

- Keep each slide focused.
- Prefer concise bullets over dense paragraphs.

## Diagram Example

```mermaid
flowchart LR
    A[Input] --> B[Wrapper]
    B --> C[Preprocessor]
    C --> D[presenterm]
```

## Table Example

| Item | Status |
|------|--------|
| Build | Ready |
| Demo | Pending |

## Thanks

Questions?
EOF

  # Use no-clobber move so an existing file is never overwritten, even on races.
  if ! mv -n -- "${tmp_init_file}" "${CWD_DIR}/${INIT_FILE}"; then
    rm -f -- "${tmp_init_file}"
    echo "Refusing to overwrite existing file: ${INIT_FILE}" >&2
    exit 1
  fi

  echo "Created presentation template: ${INIT_FILE}"
  exit 0
fi

if ! command -v kitty >/dev/null 2>&1; then
  echo "kitty is not installed or not in PATH." >&2
  exit 1
fi

if [[ "$HAS_THEME_FLAG" -eq 0 && -n "${PRESENTERM_THEME}" ]]; then
  REL_ARGS=("--theme=${PRESENTERM_THEME}" "${REL_ARGS[@]}")
fi

# Compute dynamic KITTY_FONT_SIZE from config and frontmatter
if [[ -n "$INPUT_ARG" ]]; then
  # Config file is optional — check cwd only
  config_file=""
  if [[ -f "${CWD_DIR}/presenterm-config.yaml" ]]; then
    config_file="${CWD_DIR}/presenterm-config.yaml"
  fi
  KITTY_FONT_SIZE=$(compute_kitty_font_size "$INPUT_ARG" "$config_file")
fi

WINDOW_TITLE="presenterm"
if [[ -n "$INPUT_ARG" ]]; then
  WINDOW_TITLE="$(extract_title "$INPUT_ARG")"
fi
printf -v window_title_escaped '%q' "${WINDOW_TITLE}"

docker_cmd=(
  docker run --rm -it
  --label "com.console_presenter.managed=true"
  --label "com.console_presenter.wrapper=presenterm"
  --cidfile "/tmp/presenterm-cid.$$"
  -v "${CWD_DIR}:/data"
  -w "${CONTAINER_WORKDIR}"
)

docker_cmd+=(
  "${IMAGE_NAME}:${TAG}"
  "${REL_ARGS[@]}"
)

printf -v docker_cmd_escaped '%q ' "${docker_cmd[@]}"
printf -v cwd_dir_escaped '%q' "${CWD_DIR}"
printf -v cidfile_escaped '%q' "/tmp/presenterm-cid.$$"

shell_cmd="cleanup(){ if [ -f ${cidfile_escaped} ]; then cid=\$(cat ${cidfile_escaped} 2>/dev/null || true); [ -n \"\$cid\" ] && docker rm -f \"\$cid\" >/dev/null 2>&1 || true; rm -f ${cidfile_escaped} >/dev/null 2>&1 || true; fi; }; trap cleanup EXIT HUP INT TERM QUIT; kitty @ set-tab-title ${window_title_escaped} >/dev/null 2>&1 || true; cd ${cwd_dir_escaped} && ${docker_cmd_escaped}; rc=\$?; if [ \$rc -ne 0 ]; then echo; echo 'presenterm container failed (exit '\$rc')'; echo 'Press any key to close...'; read -r -n 1 _; fi; exit \$rc"
if [[ "${PRESENTERM_DETACH}" == "0" ]]; then
  kitty --title "${WINDOW_TITLE}" --override "font_size=${KITTY_FONT_SIZE}" zsh -lc "${shell_cmd}"
else
  kitty --detach --title "${WINDOW_TITLE}" --override "font_size=${KITTY_FONT_SIZE}" zsh -lc "${shell_cmd}"
fi
