#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="${IMAGE_NAME:-presenterm-wrapper}"
TAG="${TAG:-latest}"
PRESENTERM_THEME="${PRESENTERM_THEME:-catppuccin-frappe}"
PRESENTERM_DETACH="${PRESENTERM_DETACH:-1}"

CWD_DIR="$(pwd)"
CONTAINER_WORKDIR="/data"
INPUT_ARG=""
INPUT_REL_PATH=""
HAS_THEME_FLAG=0
INIT_FILE=""

# Kitty launch font size (set to double a common default of 12).
KITTY_FONT_SIZE=32

extract_title() {
  local file="$1"
  local title=""

  # Prefer YAML frontmatter "title:" when frontmatter is present.
  if [[ "$(head -n 1 "$file")" == "---" ]]; then
    title="$(awk '
      NR==1 { in_fm=1; next }
      in_fm && /^---[[:space:]]*$/ { exit }
      in_fm && /^[[:space:]]*title[[:space:]]*:/ {
        sub(/^[[:space:]]*title[[:space:]]*:[[:space:]]*/, "", $0)
        print
        exit
      }
    ' "$file")"
  fi

  # Fallback to first H1.
  if [[ -z "$title" ]]; then
    title="$(awk '
      /^---[[:space:]]*$/ { in_fm = !in_fm; next }
      in_fm { next }
      /^[[:space:]]*#[[:space:]]+/ {
        sub(/^[[:space:]]*#[[:space:]]+/, "", $0)
        print
        exit
      }
    ' "$file")"
  fi

  # Trim surrounding quotes from frontmatter value.
  title="${title#\"}"
  title="${title%\"}"
  title="${title#\'}"
  title="${title%\'}"

  if [[ -z "$title" ]]; then
    title="$REL_INPUT_PATH"
  fi
  printf '%s\n' "$title"
}

REL_ARGS=()
expecting_init_file=0
for arg in "$@"; do
  if [[ "$expecting_init_file" -eq 1 ]]; then
    INIT_FILE="$arg"
    expecting_init_file=0
    continue
  fi

  if [[ "$arg" == "--init" ]]; then
    expecting_init_file=1
    continue
  fi
  if [[ "$arg" == --init=* ]]; then
    INIT_FILE="${arg#--init=}"
    continue
  fi

  conv="$arg"
  if [[ "$arg" == "--theme" || "$arg" == --theme=* ]]; then
    HAS_THEME_FLAG=1
  fi

  if [[ "$conv" == /* ]]; then
    case "$conv" in
      "${CWD_DIR}"/*) conv="${conv#${CWD_DIR}/}" ;;
    esac
  fi
  while [[ "$conv" == ./* ]]; do
    conv="${conv#./}"
  done

  if [[ -z "$INPUT_ARG" && "$conv" != -* && -f "${CWD_DIR}/${conv}" ]]; then
    INPUT_ARG="${arg}"
    INPUT_REL_PATH="${conv}"
    rel_dir="$(dirname -- "${INPUT_REL_PATH}")"
    if [[ "$rel_dir" != "." ]]; then
      CONTAINER_WORKDIR="/data/${rel_dir}"
    fi
  fi

  REL_ARGS+=("$conv")
done

if [[ "$expecting_init_file" -eq 1 ]]; then
  echo "Missing filename for --init" >&2
  exit 2
fi

if [[ -n "$INIT_FILE" ]]; then
  if [[ "$INIT_FILE" == */* || "$INIT_FILE" == .*/* ]]; then
    echo "--init expects a file name in the current working directory." >&2
    exit 2
  fi
  if [[ -z "$INIT_FILE" ]]; then
    echo "Missing filename for --init" >&2
    exit 2
  fi
  if [[ "$INIT_FILE" != *.md ]]; then
    echo "--init requires a markdown filename ending in .md" >&2
    exit 2
  fi
  if [[ -e "${CWD_DIR}/${INIT_FILE}" ]]; then
    echo "Refusing to overwrite existing file: ${INIT_FILE}" >&2
    exit 1
  fi

  cat > "${CWD_DIR}/${INIT_FILE}" <<'EOF'
---
title: My Presentation
author: Your Name
date: 2026-02-17
theme:
  override:
    footer:
      style: template
      left:
        image: mustwork-logo.png
---

# My Presentation

Short subtitle or context for this deck.

## Agenda

- Intro
- Main topic
- Demo
- Q&A

## Key Point

Use simple top-level headings for slide boundaries.

### Detail

- Keep each slide focused.
- Prefer concise bullets over dense paragraphs.

## Diagram Example

```mermaid
flowchart LR
    A[Input] --> B[Wrapper]
    B --> C[Preprocessor]
    C --> D[presenterm]
```

## Table Example

| Item | Status |
|------|--------|
| Build | Ready |
| Demo | Pending |

## Thanks

Questions?
EOF

  echo "Created presentation template: ${INIT_FILE}"
  exit 0
fi

if ! command -v kitty >/dev/null 2>&1; then
  echo "kitty is not installed or not in PATH." >&2
  exit 1
fi

if [[ "$HAS_THEME_FLAG" -eq 0 && -n "${PRESENTERM_THEME}" ]]; then
  REL_ARGS=("--theme=${PRESENTERM_THEME}" "${REL_ARGS[@]}")
fi

WINDOW_TITLE="presenterm"
if [[ -n "$INPUT_ARG" ]]; then
  WINDOW_TITLE="$(extract_title "$INPUT_ARG")"
fi
printf -v window_title_escaped '%q' "${WINDOW_TITLE}"

docker_cmd=(
  docker run --rm -it
  --label "com.console_presenter.managed=true"
  --label "com.console_presenter.wrapper=presenterm"
  --cidfile "/tmp/presenterm-cid.$$"
  -v "${CWD_DIR}:/data"
  -w "${CONTAINER_WORKDIR}"
  "${IMAGE_NAME}:${TAG}"
  "${REL_ARGS[@]}"
)

printf -v docker_cmd_escaped '%q ' "${docker_cmd[@]}"
printf -v cwd_dir_escaped '%q' "${CWD_DIR}"
printf -v cidfile_escaped '%q' "/tmp/presenterm-cid.$$"

shell_cmd="cleanup(){ if [ -f ${cidfile_escaped} ]; then cid=\$(cat ${cidfile_escaped} 2>/dev/null || true); [ -n \"\$cid\" ] && docker rm -f \"\$cid\" >/dev/null 2>&1 || true; rm -f ${cidfile_escaped} >/dev/null 2>&1 || true; fi; }; trap cleanup EXIT HUP INT TERM QUIT; kitty @ set-tab-title ${window_title_escaped} >/dev/null 2>&1 || true; cd ${cwd_dir_escaped} && ${docker_cmd_escaped}; rc=\$?; if [ \$rc -ne 0 ]; then echo; echo 'presenterm container failed (exit '\$rc')'; echo 'Press any key to close...'; read -r -n 1 _; fi; exit \$rc"
if [[ "${PRESENTERM_DETACH}" == "0" ]]; then
  kitty --title "${WINDOW_TITLE}" --override "font_size=${KITTY_FONT_SIZE}" zsh -lc "${shell_cmd}"
else
  kitty --detach --title "${WINDOW_TITLE}" --override "font_size=${KITTY_FONT_SIZE}" zsh -lc "${shell_cmd}"
fi
